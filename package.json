{
  "name": "crappy-bird-web-game",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "typecheck": "tsc -b --pretty false",
    "lint": "eslint .",
    "test:unit": "vitest run",
    "test:e2e": "node scripts/run-with-playwright-env.mjs playwright test",
    "verify": "npm run lint && npm run typecheck && npm run test:unit && npm run build && npm run test:e2e",
    "actual-play": "node scripts/run-with-playwright-env.mjs node scripts/actual-play.mjs"
  },
  "devDependencies": {
    "@eslint/js": "latest",
    "@playwright/test": "latest",
    "@types/node": "^25.7.0",
    "eslint": "latest",
    "typescript": "latest",
    "typescript-eslint": "latest",
    "vite": "latest",
    "vitest": "latest"
  }
}
